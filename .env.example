TZ=Asia/Shanghai
GROK2API_PORT=8000
GROK2API_IMAGE=ghcr.io/owen891/grok2api:main
GROK2API_BROWSER_IMAGE=ghcr.io/owen891/grok2api:main-browser
GROK2API_SOLVER_IMAGE=ghcr.io/owen891/grok2api:solver-0d48ecf8b4ee-fixed

# Windows local supervisor (optional; the supervisor auto-selects a safe
# worker port when GROK_WEB_BROWSER_WORKER_PORT is empty):
GROK_WEB_BROWSER_WORKER_PORT=18292
GROK2API_PROXY_PORT=7890
GROK2API_WEB_PROXY_URL=http://127.0.0.1:7890
# Set this only if bootstrapAdmin.password is not available in config.yaml.
GROK2API_ADMIN_PASSWORD=
# Set to 0 to disable automatic creation when no grok_web node exists.
GROK2API_AUTO_CONFIGURE_WEB_EGRESS=1

# Registration network mode:
# - leave REGISTRATION_PROXY empty for direct access;
# - use http://host.docker.internal:PORT for a proxy on the Docker host;
# - use a Compose service address such as socks5://warp:1080;
# - use `system` with one REGISTRATION_*_PROXY value below.
REGISTRATION_PROXY=
REGISTRATION_SOLVER_PROXY=
REGISTRATION_HTTP_PROXY=
REGISTRATION_HTTPS_PROXY=
REGISTRATION_ALL_PROXY=
TURNSTILE_THREAD=1
NO_PROXY=127.0.0.1,localhost,grok-web-browser,grok-turnstile-solver
