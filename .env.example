TZ=Asia/Shanghai
GROK2API_PORT=8000

# Registration network mode:
# - leave REGISTRATION_PROXY empty for direct access;
# - use http://host.docker.internal:PORT for a proxy on the Docker host;
# - use a Compose service address such as socks5://warp:1080;
# - use `system` with one REGISTRATION_*_PROXY value below.
REGISTRATION_PROXY=
REGISTRATION_HTTP_PROXY=
REGISTRATION_HTTPS_PROXY=
REGISTRATION_ALL_PROXY=
NO_PROXY=127.0.0.1,localhost,grok-web-browser
