GROK2API_DEPLOY_DIR=/opt/grok2api-deploy
GROK2API_RELEASE_DIR=/opt/grok2api-current
GROK2API_DATA_DIR=/opt/grok2api-data

# The registration worker reaches the solver by its Compose service name.
REGISTRATION_CAPTCHA_ENDPOINT=http://grok-turnstile-solver:5072

# Leave empty for direct access. For a proxy on the Docker host, bind that
# proxy beyond 127.0.0.1 and use http://host.docker.internal:PORT.
# For a proxy service in this Compose network, use its service name, such as
# socks5://warp:1080.
REGISTRATION_PROXY=

# Alternatively set REGISTRATION_PROXY=system and provide one of these values.
# These registration-scoped variables do not change other provider traffic.
REGISTRATION_HTTP_PROXY=
REGISTRATION_HTTPS_PROXY=
REGISTRATION_ALL_PROXY=
NO_PROXY=127.0.0.1,localhost,grok-web-browser,grok-turnstile-solver

# The solver runs in a separate browser container and needs its own concrete
# proxy URL. Use the same reachable URL as registration, never "system".
REGISTRATION_SOLVER_PROXY=

# Set to 1 temporarily when diagnosing a failed solver task.
TURNSTILE_DEBUG=0
