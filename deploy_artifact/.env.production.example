# Rolling images match the current GitHub main branch. Pin both to matching
# release tags or digests when deploying a tagged release.
GROK2API_IMAGE=ghcr.io/owen891/grok2api:main
GROK2API_BROWSER_IMAGE=ghcr.io/owen891/grok2api:main-browser
GROK2API_PORT=8000
TZ=Asia/Shanghai
# Registration runtime: protocol, browser, both, or none.
REGISTRATION_RUNTIME=protocol

POSTGRES_DB=grok2api
POSTGRES_USER=grok2api
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Only pulled when REGISTRATION_RUNTIME is protocol or both.
GROK2API_SOLVER_IMAGE=ghcr.io/owen891/grok2api:solver-0d48ecf8b4ee-fixed
REGISTRATION_PROXY=
REGISTRATION_SOLVER_PROXY=
REGISTRATION_HTTP_PROXY=
REGISTRATION_HTTPS_PROXY=
REGISTRATION_ALL_PROXY=
REGISTRATION_BROWSER_WINDOW=1280,900
REGISTRATION_XVFB_SCREEN=1280x900x24
NO_PROXY=127.0.0.1,localhost,grok-web-browser,postgres,redis,grok-turnstile-solver
