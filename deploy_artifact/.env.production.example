# Pin the application to a released tag or digest. Do not use latest/main in production.
GROK2API_IMAGE=ghcr.io/owen891/grok2api:v3.0.9
# Use the matching -browser tag only with compose.browser-registration.yml.
GROK2API_BROWSER_IMAGE=ghcr.io/owen891/grok2api:v3.0.9-browser
GROK2API_PORT=8000
TZ=Asia/Shanghai

POSTGRES_DB=grok2api
POSTGRES_USER=grok2api
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Only needed with compose.registration.yml and --profile registration.
GROK2API_SOLVER_IMAGE=ghcr.io/owen891/grok2api:solver-0d48ecf8b4ee-fixed
REGISTRATION_PROXY=
REGISTRATION_SOLVER_PROXY=
REGISTRATION_HTTP_PROXY=
REGISTRATION_HTTPS_PROXY=
REGISTRATION_ALL_PROXY=
REGISTRATION_BROWSER_WINDOW=1280,900
REGISTRATION_XVFB_SCREEN=1280x900x24
NO_PROXY=127.0.0.1,localhost,grok-web-browser,postgres,redis,grok-turnstile-solver
